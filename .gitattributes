# Public promptvcr/cli repo line-ending policy. Keeps the POSIX installer and Go
# sources LF on every checkout so they run correctly on Linux/macOS and CI.
* text=auto eol=lf

*.go  text eol=lf
*.sh  text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md  text eol=lf

# Windows installer stays CRLF.
*.ps1 text eol=crlf
